# PostgreSQL (로컬 Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password

# 서비스별 DB 이름
AUTH_DB_NAME=auth_db
USERS_DB_NAME=users_db
ORDERS_DB_NAME=orders_db

# RabbitMQ (로컬 Docker)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# 개발 환경
NODE_ENV=development
PORT=3000
